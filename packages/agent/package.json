{
  "name": "@sesari/agent",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "build": "tsc && npm run bundle",
    "bundle": "cd dist && zip -r lambda.zip .",
    "deploy": "npm run build && npx ts-node infrastructure/deploy.ts",
    "deploy:terraform": "cd infrastructure/terraform && terraform apply"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.0.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-cloudwatch": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@aws-sdk/client-iam": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0",
    "@aws-sdk/util-dynamodb": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "fast-check": "^3.15.0",
    "typescript": "^5",
    "vitest": "^1.0.0"
  }
}
