# AWS Configuration
AWS_REGION=us-east-1

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=your-knowledge-base-id

# Amazon Nova Model
NOVA_MODEL_ID=amazon.nova-lite-v1:0

# DynamoDB Tables
ANALYSIS_TABLE_NAME=icp-analysis-history
CHECKPOINT_TABLE_NAME=icp-refinement-checkpoints

# ICP Refinement Configuration
MIN_SAMPLE_SIZE=20

# Credential Vault Integration
# The ARN of the credential vault Lambda function for secure credential retrieval
CREDENTIAL_VAULT_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:credential-vault

# Environment
NODE_ENV=development

# SECURITY NOTE: API credentials (HubSpot, Mixpanel, Stripe) are NOT stored in environment variables.
# They are securely managed by the credential vault Lambda with KMS encryption.
# Users must connect services via the integration UI before running ICP refinement.

# Recursive Memory (Agentic RAG) Configuration
# S3 bucket for storing memory documents (strategy, performance, actions, technical)
MEMORY_S3_BUCKET_NAME=sesari-memory-your-unique-suffix

# Amazon Bedrock Knowledge Base ID for vector indexing and retrieval
MEMORY_BEDROCK_KB_ID=your-bedrock-kb-id

# Bedrock Knowledge Base data source ID (S3 data source)
MEMORY_BEDROCK_DATA_SOURCE_ID=your-data-source-id

# Embedding model for vector generation (default: amazon.nova-lite-v1:0)
MEMORY_EMBEDDING_MODEL=amazon.nova-lite-v1:0
