{
  "name": "@sesari/briefing-generator",
  "version": "1.0.0",
  "description": "Daily briefing generator that transforms business signals into narrative summaries",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && node infrastructure/deploy.js",
    "deploy:dynamodb": "node infrastructure/setup-dynamodb.js",
    "deploy:lambda": "npx tsx infrastructure/deploy-lambda.ts",
    "deploy:eventbridge": "node infrastructure/setup-eventbridge.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "briefing",
    "narrative",
    "bedrock",
    "lambda",
    "daily-summary"
  ],
  "author": "Sesari",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.700.0",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.2",
    "aws-sdk-client-mock": "^4.1.0",
    "fast-check": "^3.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
