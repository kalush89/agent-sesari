{
  "name": "@sesari/stripe-connector",
  "version": "1.0.0",
  "description": "Stripe webhook connector for Revenue Senses",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && node infrastructure/deploy.js",
    "deploy:dynamodb": "node infrastructure/setup-dynamodb.js",
    "deploy:lambda": "npm run build && node infrastructure/deploy-lambda.js",
    "deploy:api": "node infrastructure/setup-api-gateway.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "stripe",
    "webhook",
    "revenue",
    "lambda"
  ],
  "author": "Sesari",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.2",
    "fast-check": "^3.22.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
