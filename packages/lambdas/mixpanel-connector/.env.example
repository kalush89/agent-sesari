# Mixpanel Configuration
MIXPANEL_WEBHOOK_SECRET=your_mixpanel_webhook_signing_secret_here

# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_SIGNALS_TABLE=behavioral-signals
DYNAMODB_BASELINES_TABLE=usage-baselines

# Logging Configuration
LOG_LEVEL=info

# Detection Thresholds
ADOPTION_DROP_THRESHOLD=50
INACTIVITY_THRESHOLD_DAYS=14
POWER_USER_DAYS_THRESHOLD=20
POWER_USER_PERCENTILE=90
