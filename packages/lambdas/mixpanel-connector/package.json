{
  "name": "@sesari/mixpanel-connector",
  "version": "1.0.0",
  "description": "Mixpanel webhook monitoring system for behavioral signal detection",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && node infrastructure/deploy-webhook-lambda.js && node infrastructure/deploy-baseline-calculator-lambda.js",
    "deploy:webhook": "npm run build && node infrastructure/deploy-webhook-lambda.js",
    "deploy:baseline-calculator": "npm run build && node infrastructure/deploy-baseline-calculator-lambda.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "mixpanel": "^0.18.0"
  },
  "devDependencies": {
    "@aws-sdk/util-dynamodb": "^3.996.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.2",
    "aws-sdk-client-mock": "^4.1.0",
    "fast-check": "^3.23.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
