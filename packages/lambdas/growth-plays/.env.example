# AWS Configuration
AWS_REGION=us-east-1

# DynamoDB Tables
GROWTH_PLAYS_TABLE=sesari-growth-plays
RISK_PROFILES_TABLE=sesari-risk-profiles
SIGNAL_CACHE_TABLE=sesari-signal-cache
UNIVERSAL_SIGNALS_TABLE=sesari-universal-signals

# Bedrock Configuration
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Lambda Function Names (for invocation)
SIGNAL_ORCHESTRATOR_FUNCTION=sesari-signal-orchestrator
SIGNAL_CORRELATOR_FUNCTION=sesari-signal-correlator
DRAFT_GENERATOR_FUNCTION=sesari-draft-generator
EXECUTION_ENGINE_FUNCTION=sesari-execution-engine

# Signal Connector Functions
MIXPANEL_CONNECTOR_FUNCTION=sesari-mixpanel-connector
HUBSPOT_CONNECTOR_FUNCTION=sesari-hubspot-connector
STRIPE_CONNECTOR_FUNCTION=sesari-stripe-connector

# Communication Services
SES_FROM_EMAIL=noreply@sesari.com
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
