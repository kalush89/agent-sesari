{
  "name": "@sesari/hubspot-connector",
  "version": "1.0.0",
  "description": "HubSpot webhook connector for Relationship Senses",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "node infrastructure/deploy-webhook-lambda.ts && node infrastructure/deploy-gap-detector-lambda.ts",
    "deploy:webhook": "node infrastructure/deploy-webhook-lambda.ts",
    "deploy:gap-detector": "node infrastructure/deploy-gap-detector-lambda.ts"
  },
  "dependencies": {
    "@hubspot/api-client": "^11.2.0",
    "@aws-sdk/client-dynamodb": "^3.515.0",
    "@aws-sdk/lib-dynamodb": "^3.515.0",
    "@aws-sdk/util-dynamodb": "^3.515.0",
    "@aws-sdk/client-cloudwatch": "^3.515.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/node": "^20.11.19",
    "fast-check": "^3.15.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
